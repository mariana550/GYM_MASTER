  "components": {
    "schemas": {
      "AsignarRutinaDTO": {
        "required": [
          "rutinaId",
          "usuarioId"
        ],
        "type": "object",
        "properties": {
          "usuarioId": {
            "type": "integer",
            "format": "int32"
          },
          "rutinaId": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ChatDTO": {
        "type": "object",
        "properties": {
          "mensaje": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CrearProgresoDTO": {
        "type": "object",
        "properties": {
          "peso": {
            "maximum": 300,
            "minimum": 30,
            "type": "number",
            "format": "double"
          },
          "altura": {
            "maximum": 250,
            "minimum": 100,
            "type": "number",
            "format": "double"
          },
          "porcentajeGrasa": {
            "maximum": 100,
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "notas": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "EditarPerfilDTO": {
        "type": "object",
        "properties": {
          "nombre": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "format": "email",
            "nullable": true
          },
          "nuevaPassword": {
            "minLength": 6,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "EditarRutinaDTO": {
        "type": "object",
        "properties": {
          "nombre": {
            "maxLength": 150,
            "type": "string",
            "nullable": true
          },
          "descripcion": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "objetivo": {
            "type": "string",
            "nullable": true
          },
          "duracionSemanas": {
            "maximum": 52,
            "minimum": 1,
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "EditarUsuarioDTO": {
        "type": "object",
        "properties": {
          "nombre": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "format": "email",
            "nullable": true
          },
          "rol": {
            "type": "string",
            "nullable": true
          },
          "activo": {
            "type": "boolean",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginDTO": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RegisterDTO": {
        "required": [
          "email",
          "nombre",
          "password"
        ],
        "type": "object",
        "properties": {
          "nombre": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          },
          "rol": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RutinaDTO": {
        "required": [
          "nombre",
          "objetivo"
        ],
        "type": "object",
        "properties": {
          "nombre": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string"
          },
          "descripcion": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "objetivo": {
            "minLength": 1,
            "type": "string"
          },
          "duracionSemanas": {
            "maximum": 52,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "Escribe: Bearer {token}",
        "name": "Authorization",
        "in": "header"
